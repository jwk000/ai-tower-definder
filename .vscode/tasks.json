{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "npm",
      "script": "dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^  VITE",
          "endsPattern": "^  VITE"
        }
      }
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "tsc: watch",
      "type": "shell",
      "command": "npx tsc --noEmit --watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    }
  ]
}
