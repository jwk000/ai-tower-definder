{
  "name": "tower-defender",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rimraf dist",
    "release": "npm run typecheck && npm run clean && vite build && echo 'Build complete: dist/'",
    "release:preview": "npm run release && vite preview"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "bitecs": "~0.3.40",
    "js-yaml": "^4.1.1",
    "pixi.js": "^8.18.1"
  }
}
